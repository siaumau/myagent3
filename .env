# Remote LLM endpoint (used by the server when forwarding /chat requests)
REMOTE_API_URL=https://ai2.aischool.edu.pl/v1/chat/completions

# Optional API key for the remote service (leave empty if not required)
API_KEY=abcd1234

# Optional: enable context recording (true/false)
RECORD_CONTEXT=true

# Database configuration
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai
DB_USER=root
DB_PASSWORD=password
