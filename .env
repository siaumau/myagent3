# Remote LLM endpoint (used by the server when forwarding /chat requests)
REMOTE_API_URL=https://ai2.aischool.edu.pl/v1/chat/completions

# Optional API key for the remote service (leave empty if not required)
API_KEY=abcd1234

# Optional: enable context recording (true/false)
RECORD_CONTEXT=true

# Database configuration
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai
DB_USER=root
DB_PASSWORD=password

# Image Processing Configuration
IMAGE_PROCESSOR_ENABLED=true
IMAGE_INPUT_FOLDER=job_img
IMAGE_OUTPUT_FOLDER=job_img_ok
IMAGE_AI_API_URL=https://ai3.aischool.edu.pl/v1/chat/completions
IMAGE_AI_MODEL=Qwen2-VL-2B-Instruct
IMAGE_PROCESSOR_INTERVAL_MS=60000
IMAGE_PROCESSOR_LOG_ENABLED=true
